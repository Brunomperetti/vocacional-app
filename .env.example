# Nombre público de la aplicación.
APP_NAME=Vocación360

# PostgreSQL en producción o SQLite local si se omite.
# DATABASE_URL=postgresql://usuario:password@host:5432/vocacional
DATABASE_URL=sqlite:///./vocacional_dev.db

# Link externo opcional para aporte voluntario (por ejemplo, Mercado Pago).
DONATION_URL=

# URL pública opcional de la app para enlaces compartidos (por ejemplo, https://tu-app.onrender.com).
PUBLIC_APP_URL=

# Credenciales para proteger el panel /admin.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Medición opcional de marketing. Si se omiten, no se renderizan scripts.
GA_MEASUREMENT_ID=
META_PIXEL_ID=

# Link opcional al perfil del creador en la landing. Debe ser una URL https.
CREATOR_LINKEDIN_URL=
